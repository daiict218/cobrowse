{
  "name": "@cobrowse/server",
  "version": "1.0.0",
  "description": "CoBrowse session server — multi-tenant relay, session lifecycle, audit",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:migrate": "node src/db/migrate.js",
    "db:seed": "node src/db/seed.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^11.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "@fastify/static": "^7.0.0",
    "ably": "^2.6.0",
    "bullmq": "^5.70.1",
    "dotenv": "^16.4.0",
    "fastify": "^4.27.0",
    "ioredis": "^5.9.3",
    "pg": "^8.11.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "vitest": "^4.0.18"
  }
}
