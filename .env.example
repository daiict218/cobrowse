# ─── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ─── Database ─────────────────────────────────────────────────────────────────
# Docker (default)
DATABASE_URL=postgresql://cobrowse:cobrowse_dev@localhost:5432/cobrowse

# Cloud alternatives (uncomment one):
# Supabase:   DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
# Neon:       DATABASE_URL=postgresql://[user]:[password]@[host].neon.tech/cobrowse?sslmode=require

# ─── Cache + Distributed Timers ──────────────────────────────────────────────
# Set to "memory" for zero-dependency local dev, "redis" for production.
# When CACHE_DRIVER=redis, session timers (idle, max-duration) use BullMQ
# delayed jobs — they survive server restarts and work across multiple instances.
CACHE_DRIVER=memory
# Format with password: redis://:your_password@localhost:6379
REDIS_URL=redis://localhost:6379

# ─── Ably ─────────────────────────────────────────────────────────────────────
# Get your API key from https://ably.com → Apps → API Keys
ABLY_API_KEY=your_ably_api_key_here

# ─── Security ─────────────────────────────────────────────────────────────────
# 32+ random characters, used to sign session tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_SECRET=change_this_to_a_random_secret_at_least_32_chars

# ─── Snapshot storage ─────────────────────────────────────────────────────────
# TTL in seconds for initial DOM snapshots (default: 2 hours)
SNAPSHOT_TTL_SECONDS=7200

# ─── Session limits ───────────────────────────────────────────────────────────
SESSION_MAX_DURATION_MINUTES=120
SESSION_IDLE_TIMEOUT_MINUTES=10

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated origins allowed to call the API (demo defaults)
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
