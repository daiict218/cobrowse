{
  "name": "cobrowse",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-tenant co-browsing platform",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/server",
    "build:sdk": "npm run build --workspace=packages/sdk",
    "build:agent-sdk": "npm run build --workspace=packages/agent-sdk",
    "db:migrate": "npm run db:migrate --workspace=packages/server",
    "db:seed": "npm run db:seed --workspace=packages/server",
    "start": "npm run start --workspace=packages/server",
    "test": "npm run test --workspace=packages/server && npm run test --workspace=packages/sdk",
    "test:coverage": "npm run test:coverage --workspace=packages/server && npm run test:coverage --workspace=packages/sdk"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
